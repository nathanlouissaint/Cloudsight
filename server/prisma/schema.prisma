generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgets Budget[]
  reports Report[]
}

model CloudService {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  costRecords CostRecord[]

  createdAt DateTime @default(now())
}

model CostRecord {
  id String @id @default(uuid())

  serviceId String
  service   CloudService @relation(fields: [serviceId], references: [id])

  usageDate DateTime
  cost      Float

  createdAt DateTime @default(now())
}

model CloudAccount {
  id String @id @default(uuid())

  awsAccountId String @unique
  accountName  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots        CostSnapshot[]
  serviceSnapshots ServiceCostSnapshot[]
}

model CostSnapshot {
  id String @id @default(uuid())

  accountId String
  account   CloudAccount @relation(fields: [accountId], references: [id])

  snapshotDate DateTime

  totalCost Float

  createdAt DateTime @default(now())

  @@index([snapshotDate])
}

model ServiceCostSnapshot {
  id String @id @default(uuid())

  accountId String
  account   CloudAccount @relation(fields: [accountId], references: [id])

  serviceName String

  snapshotDate DateTime

  cost Float

  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([snapshotDate])
  @@index([serviceName])
}

model BudgetSnapshot {
  id String @id @default(uuid())

  budgetName   String
  budgetAmount Float
  actualSpend  Float

  snapshotDate DateTime

  createdAt DateTime @default(now())

  @@index([snapshotDate])
}

model Budget {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  name   String
  amount Float

  month Int
  year  Int

  createdAt DateTime @default(now())
}

model Alert {
  id          String @id @default(uuid())
  title       String
  description String
  severity    String

  createdAt DateTime @default(now())
}

model AlertHistory {
  id String @id @default(uuid())

  alertId  String
  type     String
  severity String
  status   String

  title          String
  description    String
  recommendation String

  metric       String
  currentValue Float
  threshold    Float

  occurredAt DateTime
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([alertId])
  @@index([severity])
  @@index([status])
  @@index([occurredAt])
}

model Forecast {
  id            String   @id @default(uuid())
  forecastDate  DateTime
  projectedCost Float

  createdAt DateTime @default(now())
}

model Report {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  summary String

  createdAt DateTime @default(now())
}
